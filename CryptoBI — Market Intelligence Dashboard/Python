# ─── Cross-source price aggregation ─────────────────────────────────────────

@st.cache_data(ttl=60)
def fetch_cross_source_prices(cmc_df: pd.DataFrame):
    SYMBOLS = ["BTC","ETH","BNB","SOL","XRP","ADA","DOGE","TRX","LINK","AVAX",
               "DOT","MATIC","UNI","ATOM","LTC","BCH","XLM","ALGO","VET","FTM"]

    lcw = fetch_livecoinwatch(SYMBOLS)

    rows = []
    for sym in SYMBOLS:
        cmc_row = cmc_df[cmc_df["symbol"] == sym]
        if cmc_row.empty:
            continue
        cmc_price  = float(cmc_row["price"].iloc[0])
        cmc_pct24h = float(cmc_row["pct24h"].iloc[0])
        lcw_data   = lcw.get(sym, {})
        lcw_price  = lcw_data.get("price", None)
        lcw_pct24h = lcw_data.get("pct24h", None)

        sources_price = [p for p in [cmc_price, lcw_price] if p]
        avg_price = sum(sources_price) / len(sources_price)
        diff_pct  = ((cmc_price / lcw_price) - 1) * 100 if lcw_price else 0

        sources_pct = [p for p in [cmc_pct24h, lcw_pct24h] if p is not None]
        avg_pct = sum(sources_pct) / len(sources_pct) if sources_pct else 0

        rows.append({
            "symbol":       sym,
            "price_cmc":    cmc_price,
            "price_lcw":    lcw_price,
            "price_avg":    avg_price,
            "diff_pct":     diff_pct,
            "pct24h_cmc":   cmc_pct24h,
            "pct24h_lcw":   lcw_pct24h,
            "pct24h_avg":   avg_pct,
            "n_sources":    len(sources_price),
        })
    return pd.DataFrame(rows)


