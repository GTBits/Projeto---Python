def fu(v, d=2):
    if v is None or (isinstance(v, float) and np.isnan(v)): return "—"
    if v >= 1e12: return f"${v/1e12:.2f}T"
    if v >= 1e9:  return f"${v/1e9:.2f}B"
    if v >= 1e6:  return f"${v/1e6:.2f}M"
    if v >= 1e3:  return f"${v:,.{d}f}"
    if v >= 1:    return f"${v:.{d}f}"
    return f"${v:.6f}"

