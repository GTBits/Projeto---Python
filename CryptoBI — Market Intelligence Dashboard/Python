        r_lat = requests.get(
            "https://pro-api.coinmarketcap.com/v3/fear-and-greed/latest",
            headers={"Accepts": "application/json", "X-CMC_PRO_API_KEY": CHAVE_COINMARKETCAP},
            timeout=8,
        )
        latest_val = None
        if r_lat.status_code == 200:
            d = r_lat.json().get("data", {})
            latest_val = int(d.get("value", 0)) if d else None

        # Historical
        r_hist = requests.get(
            "https://pro-api.coinmarketcap.com/v3/fear-and-greed/historical",
            headers={"Accepts": "application/json", "X-CMC_PRO_API_KEY": CHAVE_COINMARKETCAP},
            params={"limit": str(limit)},
            timeout=10,
        )
        hist_df = pd.DataFrame()
