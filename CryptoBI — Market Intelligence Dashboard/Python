@st.cache_data(ttl=60)
def fetch_livecoinwatch(symbols=None):
    if symbols is None:
        symbols = ["BTC","ETH","BNB","SOL","XRP","ADA","DOGE","TRX","USDT","USDC"]
    try:
        results = {}
