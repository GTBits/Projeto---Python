@st.cache_data(ttl=60)
def fetch_crypto(limit=100):
    try:
        url = "https://pro-api.coinmarketcap.com/v1/cryptocurrency/listings/latest"
        r = requests.get(url,
            params={"start":"1","limit":str(limit),"convert":"USD"},
            headers={"Accepts":"application/json","X-CMC_PRO_API_KEY":CHAVE_COINMARKETCAP},
            timeout=12)
        r.raise_for_status()
        rows = []
        for c in r.json()["data"]:
            q = c["quote"]["USD"]
            rows.append({
                "rank":   c["cmc_rank"],
                "name":   c["name"],
                "symbol": c["symbol"],
                "price":  q["price"],
                "pct24h": q.get("percent_change_24h") or 0,
                "pct7d":  q.get("percent_change_7d")  or 0,
                "pct30d": q.get("percent_change_30d", 0) or 0,
                "mcap":   q.get("market_cap") or 0,
                "vol24h": q.get("volume_24h") or 0,
                "supply": c.get("circulating_supply") or 0,
            })
        return pd.DataFrame(rows)
    except Exception as e:
        st.error(f"CoinMarketCap error: {e}")
        return pd.DataFrame()


