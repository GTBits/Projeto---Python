                    "price":   d.get("rate", 0),
                    "pct24h":  (d.get("delta", {}).get("day", 1) - 1) * 100,
                    "vol24h":  d.get("volume", 0),
                    "mcap":    d.get("cap", 0),
                    "source":  "LiveCoinWatch",
                }
