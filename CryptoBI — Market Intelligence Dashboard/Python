def calc_rsi(series, period=14):
    delta = series.diff()
    gain  = delta.clip(lower=0)
    loss  = -delta.clip(upper=0)
    ag = gain.ewm(com=period - 1, min_periods=period).mean()
    al = loss.ewm(com=period - 1, min_periods=period).mean()
    rs = ag / al
    return (100 - 100 / (1 + rs)).rename("RSI")


def calc_macd(series, fast=12, slow=26, signal=9):
    ema_f = series.ewm(span=fast, adjust=False).mean()
    ema_s = series.ewm(span=slow, adjust=False).mean()
    macd  = ema_f - ema_s
    sig   = macd.ewm(span=signal, adjust=False).mean()
    hist  = macd - sig
    return macd.rename("MACD"), sig.rename("Signal"), hist.rename("Hist")


def calc_pi_cycle(df_hist):
    df = df_hist[["Close"]].copy().dropna()
    df["SMA111"]   = df["Close"].rolling(111).mean()
    df["SMA350x2"] = df["Close"].rolling(350).mean() * 2
    return df


def make_rainbow_chart(df_hist):
    df = df_hist[["Close"]].copy().dropna()
    genesis = pd.Timestamp("2009-01-03")
    df["days"] = (df.index - genesis).days
    df = df[df["days"] > 0]

    x = np.log10(df["days"].values.astype(float))
    y = np.log10(df["Close"].values.astype(float))
    mask = np.isfinite(x) & np.isfinite(y)
    a, b = np.polyfit(x[mask], y[mask], 1)

    max_days = int(df["days"].max())
    proj_days = max_days + 730
    all_days  = np.arange(1, proj_days + 1)
    all_dates = [genesis + timedelta(days=int(d)) for d in all_days]

    log_reg = a * np.log10(all_days.astype(float)) + b

    step = 0.22
    offsets = [step * (i - 4.5) for i in range(10)]

    colors_rgba = [
        "rgba(13,71,161,0.35)",
        "rgba(21,101,192,0.35)",
        "rgba(25,118,210,0.35)",
        "rgba(46,125,50,0.35)",
        "rgba(56,142,60,0.35)",
        "rgba(249,168,37,0.35)",
        "rgba(245,124,0,0.35)",
        "rgba(229,57,53,0.35)",
        "rgba(183,28,28,0.35)",
    ]
    colors_solid = ["#0d47a1","#1565c0","#1976d2","#2e7d32","#388e3c",
                    "#f9a825","#f57c00","#e53935","#b71c1c"]
    labels = [
        "Maximum Bubble Territory",
        "Sell. Seriously, SELL!",
        "FOMO Intensifies",
        "Is This a Bubble?",
        "HODL",
        "Still Cheap",
        "Accumulate",
        "Buy!",
        "Basically a Fire Sale",
    ]

    fig = go.Figure()

    band_prices = [10 ** (log_reg + off) for off in offsets]

    for i in range(9):
        fig.add_trace(go.Scatter(
            x=all_dates, y=band_prices[i + 1],
            mode="lines", line=dict(width=0),
            showlegend=False, hoverinfo="skip",
        ))
        fig.add_trace(go.Scatter(
            x=all_dates, y=band_prices[i],
            mode="lines", line=dict(width=0),
            fill="tonexty",
            fillcolor=colors_rgba[i],
            name=labels[8 - i],
            hoverinfo="skip",
            legendgroup=labels[8 - i],
            showlegend=True,
        ))

    fig.add_trace(go.Scatter(
        x=all_dates, y=10 ** log_reg,
        mode="lines", name="Log Regression",
        line=dict(color=C["blue"], width=1, dash="dot"),
        hovertemplate="Regression: $%{y:,.0f}<extra></extra>",
    ))

    fig.add_trace(go.Scatter(
        x=df.index, y=df["Close"],
        mode="lines", name="BTC / USD",
        line=dict(color="#ffffff", width=1.8),
        hovertemplate="<b>%{x|%Y-%m-%d}</b><br>$%{y:,.0f}<extra></extra>",
    ))

    last_price = float(df["Close"].iloc[-1])
    last_date  = df.index[-1]
    fig.add_trace(go.Scatter(
        x=[last_date], y=[last_price],
        mode="markers", name="Current Price",
        marker=dict(color="#ffffff", size=8, symbol="circle",
                    line=dict(color=C["blue"], width=2)),
        hovertemplate=f"<b>Now</b>: ${last_price:,.0f}<extra></extra>",
    ))

    # ── Calcular range Y justo: do bottom band até o top band no range de datas visíveis
    # Usamos os dias do início do BTC até a projeção
